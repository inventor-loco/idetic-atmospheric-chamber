; Copy this file to secrets.ini and fill in real values.
; secrets.ini is git-ignored so credentials never reach the repo.

[secrets]
build_flags =
    -DWIFI_SSID=\"your-lab-ssid\"
    -DWIFI_PASSWORD=\"your-wifi-password\"
    -DMQTT_HOST=\"192.168.1.10\"      ; Raspberry Pi 5 broker IP
    -DMQTT_PORT=1883
    -DMODULE_ID=\"m1\"                 ; m1 .. m5, unique per board
